{
    "name": "vetios",
    "private": true,
    "scripts": {
        "build": "turbo run build",
        "dev": "turbo run dev",
        "lint": "turbo run lint",
        "test:adversarial-regressions": "node --experimental-strip-types --loader ./internal/testing/alias-loader.mjs ./internal/testing/test_adversarial_regressions.ts",
        "typecheck": "turbo run typecheck",
        "clean": "turbo run clean",
        "format": "prettier --write \"**/*.{ts,tsx,md,json}\""
    },
    "devDependencies": {
        "prettier": "^3.2.0",
        "turbo": "^2.3.0",
        "typescript": "^5.7.0"
    },
    "pnpm": {
        "overrides": {
            "brace-expansion@1.1.12": "1.1.13",
            "brace-expansion@2.0.2": "2.0.3",
            "flatted@3.3.3": "3.4.2",
            "glob@10.3.10": "10.5.0",
            "minimatch@9.0.3": "9.0.7",
            "picomatch@2.3.1": "2.3.2",
            "picomatch@4.0.3": "4.0.4"
        }
    },
    "engines": {
        "node": "20.x"
    },
    "packageManager": "pnpm@9.14.4"
}
