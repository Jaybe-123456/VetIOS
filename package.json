{
    "name": "vetios",
    "private": true,
    "scripts": {
        "build": "turbo run build",
        "dev": "turbo run dev",
        "lint": "turbo run lint",
        "security:audit": "pnpm audit --prod",
        "security:routes": "pnpm --filter @vetios/web run test:api-auth-surface",
        "cire:conformance": "pnpm --filter @vetios/cire-engine test",
        "test:adversarial-regressions": "node --experimental-strip-types --loader ./internal/testing/alias-loader.mjs ./internal/testing/test_adversarial_regressions.ts",
        "typecheck": "turbo run typecheck",
        "clean": "turbo run clean",
        "format": "prettier --write \"**/*.{ts,tsx,md,json}\""
    },
    "devDependencies": {
        "prettier": "^3.2.0",
        "turbo": "^2.9.14",
        "typescript": "^5.7.0"
    },
    "pnpm": {
        "overrides": {
            "@babel/core": "7.29.6",
            "brace-expansion@1.1.12": "1.1.13",
            "brace-expansion@2.0.2": "2.0.3",
            "brace-expansion@5.0.5": "5.0.6",
            "flatted@3.3.3": "3.4.2",
            "glob@10.3.10": "10.5.0",
            "js-yaml": "4.2.0",
            "minimatch@9.0.3": "9.0.7",
            "picomatch@2.3.1": "2.3.2",
            "picomatch@4.0.3": "4.0.4",
            "dompurify": "3.4.11",
            "express-rate-limit": "8.5.2",
            "fast-uri": "3.1.2",
            "hono": "4.12.26",
            "ip-address": "10.1.1",
            "postcss": "8.5.14",
            "qs": "6.15.2",
            "typescript": ">=5.7.0 <6.0.0",
            "ws": "8.21.0"
        }
    },
    "engines": {
        "node": "20.x"
    },
    "packageManager": "pnpm@9.14.4"
}
