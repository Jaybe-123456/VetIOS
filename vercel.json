{
  "framework": "nextjs",
  "buildCommand": "pnpm --workspace-root run build --filter=@vetios/web",
  "outputDirectory": ".next",
  "functions": {
    "app/api/**": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/outbox-flush",
      "schedule": "*/1 * * * *"
    }
  ]
}
