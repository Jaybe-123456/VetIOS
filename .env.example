# VetIOS Environment Configuration
# Copy this file to .env.local and fill in your values.

# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── AI Provider (OpenAI-compatible) ─────────────────────────────────────────
AI_PROVIDER_NAME=openai
AI_PROVIDER_BASE_URL=https://api.openai.com/v1
AI_PROVIDER_API_KEY=sk-your-openai-api-key-here
AI_PROVIDER_DEFAULT_MODEL=gpt-4-turbo
AI_PROVIDER_EMBEDDING_MODEL=text-embedding-3-small

# ─── Optional: Fallback AI Provider ──────────────────────────────────────────
# AI_FALLBACK_PROVIDER_NAME=azure
# AI_FALLBACK_PROVIDER_BASE_URL=https://your-resource.openai.azure.com/openai/deployments/your-deployment
# AI_FALLBACK_PROVIDER_API_KEY=your-azure-key
# AI_FALLBACK_PROVIDER_DEFAULT_MODEL=gpt-4

# ─── Application ─────────────────────────────────────────────────────────────
LOG_LEVEL=info
NEXT_PUBLIC_SITE_URL=https://app.vetios.example
SITE_URL=https://app.vetios.example

# ─── Authentication Hardening ────────────────────────────────────────────────
AUTH_MAX_FAILURES=5
AUTH_CAPTCHA_AFTER_FAILURES=3
AUTH_FAILURE_LOOKBACK_MINUTES=1440
AUTH_LOCKOUT_MINUTES=30
AUTH_IP_BLOCK_AFTER_FAILURES=10
AUTH_IP_BLOCK_LOOKBACK_MINUTES=60
AUTH_IP_BLOCK_MINUTES=60
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key
PASSIVE_CONNECTOR_INGEST_KEY=shared-secret-for-vendor-connectors
