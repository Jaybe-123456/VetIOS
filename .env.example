# VetIOS Environment Configuration
# Copy this file to .env.local and fill in your values.

# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Supabase connection pooler (use for direct server-side PostgreSQL clients at scale)
# Find in: Supabase Dashboard -> Settings -> Database -> Connection Pooling
SUPABASE_DB_POOLER_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ─── AI Provider (OpenAI-compatible) ─────────────────────────────────────────
AI_PROVIDER_NAME=openai
AI_PROVIDER_BASE_URL=https://api.openai.com/v1
AI_PROVIDER_API_KEY=sk-your-openai-api-key-here
AI_PROVIDER_DEFAULT_MODEL=gpt-4-turbo
AI_PROVIDER_EMBEDDING_MODEL=text-embedding-3-small

# ─── Optional: Fallback AI Provider ──────────────────────────────────────────
# AI_FALLBACK_PROVIDER_NAME=azure
# AI_FALLBACK_PROVIDER_BASE_URL=https://your-resource.openai.azure.com/openai/deployments/your-deployment
# AI_FALLBACK_PROVIDER_API_KEY=your-azure-key
# AI_FALLBACK_PROVIDER_DEFAULT_MODEL=gpt-4
# Anthropic enrichment for Ask VetIOS visual and formulary panels
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Optional image search providers for Ask VetIOS Clinical Images panel
# Preferred order in code: Google Custom Search -> Bing Image Search
BING_IMAGE_SEARCH_API_KEY=
BING_IMAGE_SEARCH_ENDPOINT=https://api.bing.microsoft.com/v7.0/images/search
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=

# ─── Application ─────────────────────────────────────────────────────────────
LOG_LEVEL=info
NEXT_PUBLIC_SITE_URL=https://app.vetios.example
SITE_URL=https://app.vetios.example
VETIOS_PUBLIC_TENANT_ID=
VETIOS_PUBLIC_PLATFORM_DETAILS=false
RESEND_API_KEY=re_replace_me
VETIOS_EMAIL_FROM=VetIOS <noreply@vetios.example>
VETIOS_EMAIL_REPLY_TO=support@vetios.example

# ─── Authentication Hardening ────────────────────────────────────────────────
AUTH_MAX_FAILURES=5
AUTH_CAPTCHA_AFTER_FAILURES=3
AUTH_FAILURE_LOOKBACK_MINUTES=1440
AUTH_LOCKOUT_MINUTES=30
AUTH_IP_BLOCK_AFTER_FAILURES=10
AUTH_IP_BLOCK_LOOKBACK_MINUTES=60
AUTH_IP_BLOCK_MINUTES=60
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key
PASSIVE_CONNECTOR_INGEST_KEY=shared-secret-for-vendor-connectors
VETIOS_INTERNAL_API_TOKEN=internal-operator-token
# Generate a 32-character random hex string for Vercel cron authorization.
CRON_SECRET=replace-with-32-char-random-hex
VETIOS_OUTBOX_BATCH_SIZE=25
VETIOS_OUTBOX_CRON_MAX_BATCHES=4
OUTBOX_WEBHOOK_SIGNING_SECRET=replace-with-webhook-signing-secret

# Stripe + Developer API Billing
STRIPE_SECRET_KEY=sk_live_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_SANDBOX_PRICE_ID=price_sandbox_replace_me
STRIPE_CLINIC_PRICE_ID=price_clinic_replace_me
STRIPE_RESEARCH_PRICE_ID=price_research_replace_me
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_replace_me
API_KEY_SIGNING_SECRET=replace-with-32-char-random-hex
VETIOS_API_BASE_URL=https://api.vetios.tech

# ─── Phase 2 Intelligence Stack ───────────────────────────────────────────────
# CRON_SECRET: authorises Vercel cron scheduler — add to Vercel dashboard too
# CRON_SECRET is set in Vercel dashboard only — never commit the real value here
VETIOS_EMBEDDING_DIMENSIONS=1536
VETIOS_EMBEDDING_MODEL=text-embedding-3-large
VETIOS_POPULATION_SIGNAL_ENABLED=true
VETIOS_OUTBREAK_ALERT_WEBHOOK=
VETIOS_ACTIVE_LEARNING_ENABLED=true
VETIOS_AL_UNCERTAINTY_THRESHOLD=0.55
VETIOS_CONSTITUTIONAL_AI_ENABLED=true
VETIOS_CONFIDENCE_GATE_THRESHOLD=0.65
VETIOS_MULTI_AGENT_ENABLED=true
NEXT_PUBLIC_APP_URL=https://app.vetios.tech
