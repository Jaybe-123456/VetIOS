# VetIOS Environment Configuration
# Copy this file to .env.local and fill in your values.

# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Supabase connection pooler (use for direct server-side PostgreSQL clients at scale)
# Find in: Supabase Dashboard -> Settings -> Database -> Connection Pooling
SUPABASE_DB_POOLER_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ─── AI Provider (OpenAI-compatible) ─────────────────────────────────────────
HF_API_URL=https://api-inference.huggingface.co/models/<your-model-id>
HF_API_TOKEN=hf_...
OPENAI_API_KEY=sk-...
OPENAI_FALLBACK_MODEL=gpt-4o-mini

AI_PRIMARY_PROVIDER=openai
AI_PROVIDER_NAME=openai
AI_PROVIDER_BASE_URL=https://api.openai.com/v1
AI_PROVIDER_API_KEY=sk-your-openai-api-key-here
# VetIOS standardizes on gpt-4o-mini for the core inference loop.
AI_PROVIDER_DEFAULT_MODEL=gpt-4o-mini
AI_PROVIDER_EMBEDDING_MODEL=text-embedding-3-small

# Optional latency optimization for custom OpenAI-compatible model servers.
# True speculative decoding must be enabled/supported by the generation server
# (for example vLLM, TensorRT-LLM, SGLang, or a managed backend exposing a
# compatible request extension). VetIOS never sends these fields to public
# api.openai.com unless AI_SPECULATIVE_DECODING_ALLOW_OPENAI=true is set.
AI_SPECULATIVE_DECODING_ENABLED=false
# server = backend configured out-of-band; top_level/extra_body = send request hints.
AI_SPECULATIVE_DECODING_MODE=server
AI_SPECULATIVE_DRAFT_MODEL=
AI_SPECULATIVE_NUM_DRAFT_TOKENS=4
AI_SPECULATIVE_DECODING_ALLOW_OPENAI=false

# ─── Optional: Fallback AI Provider ──────────────────────────────────────────
AI_FALLBACK_PROVIDER_NAME=azure
AI_FALLBACK_PROVIDER=azure
AI_FALLBACK_PROVIDER_BASE_URL=https://your-resource.openai.azure.com/openai/deployments/your-deployment
AI_FALLBACK_PROVIDER_API_KEY=your-azure-key
AI_FALLBACK_PROVIDER_DEFAULT_MODEL=gpt-4o-mini
# Anthropic enrichment for Ask VetIOS visual and formulary panels
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# ─── Quantum Service ─────────────────────────────────────────────────────────
QUANTUM_SERVICE_URL=http://localhost:8001
QUANTUM_ENABLED=false
QUANTUM_BACKEND=simulator
QUANTUM_SERVICE_TIMEOUT_MS=10000
QUANTUM_GBS_SAMPLES=20
QUANTUM_GBS_ITERATIONS=5
AWS_BRAKET_ARN=

# ─── AMR Genomics ────────────────────────────────────────────────────────────
AMR_CARD_DB_VERSION=local-marker-v1
AWS_BEDROCK_REGION=us-east-1

# Optional image search providers for Ask VetIOS Clinical Images panel
# Preferred order in code: Google Custom Search -> Bing Image Search
BING_IMAGE_SEARCH_API_KEY=
BING_IMAGE_SEARCH_ENDPOINT=https://api.bing.microsoft.com/v7.0/images/search
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=

# ─── Application ─────────────────────────────────────────────────────────────
LOG_LEVEL=info
NEXT_PUBLIC_SITE_URL=https://app.vetios.example
SITE_URL=https://app.vetios.example
VETIOS_PUBLIC_TENANT_ID=
VETIOS_PUBLIC_PLATFORM_DETAILS=false
RESEND_API_KEY=re_replace_me
VETIOS_EMAIL_FROM=VetIOS <noreply@vetios.example>
VETIOS_EMAIL_REPLY_TO=support@vetios.example

# ─── Authentication Hardening ────────────────────────────────────────────────
AUTH_MAX_FAILURES=5
AUTH_CAPTCHA_AFTER_FAILURES=3
AUTH_FAILURE_LOOKBACK_MINUTES=1440
AUTH_LOCKOUT_MINUTES=30
AUTH_IP_BLOCK_AFTER_FAILURES=10
AUTH_IP_BLOCK_LOOKBACK_MINUTES=60
AUTH_IP_BLOCK_MINUTES=60
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key
PASSIVE_CONNECTOR_INGEST_KEY=shared-secret-for-vendor-connectors
VETIOS_INTERNAL_API_TOKEN=internal-operator-token
VETIOS_ALLOWED_ORIGINS=https://www.vetios.tech,https://vetios.tech,https://app.vetios.tech
VETIOS_CLIENT_ATTESTATION_SECRET=replace-with-32-char-random-hex
VETIOS_PROTECTION_REPORT_ONLY=true
VETIOS_STRICT_ORIGIN_GUARD=false
VETIOS_STRICT_CLIENT_ATTESTATION=false
# Production mTLS edge proxy trust. Required for OAuth clients with mtls_required=true.
# Generate a 32-byte random hex value and set the same value on the trusted proxy.
VETIOS_MTLS_PROXY_SECRET=
# Optional alias supported by the app. Prefer VETIOS_MTLS_PROXY_SECRET unless rotating names.
VETIOS_TRUSTED_MTLS_PROXY_SECRET=
# Emergency local-only/testing escape hatch. Keep false/unset in production.
VETIOS_ALLOW_UNTRUSTED_MTLS_PROXY=false
# Generate a 32-character random hex string for Vercel cron authorization.
CRON_SECRET=replace-with-32-char-random-hex
VETIOS_PUBLIC_RAG_TENANT_ID=public
VETIOS_RAG_EMBEDDING_MODEL=text-embedding-3-small
VETIOS_RAG_EUTILS_BASE_URL=https://eutils.ncbi.nlm.nih.gov/entrez/eutils
VETIOS_RAG_CONNECTOR_MAX_RECORDS=8
VETIOS_NCBI_TOOL=vetios_agentic_rag
VETIOS_NCBI_EMAIL=
VETIOS_NCBI_API_KEY=

# Global One Health / biomedical ontology population
# These values are required before the ontology completion snapshot can become fully_populated.
# UMLS requires an NLM UMLS API key.
UMLS_API_KEY=
# WHO ICD-11 API credentials are issued by WHO ICD API registration.
WHO_ICD_CLIENT_ID=
WHO_ICD_CLIENT_SECRET=
# NCBI E-utilities can run without an API key at lower rate limits, but production ingestion should set one.
NCBI_API_KEY=
# Official export URLs should point to controlled, versioned JSON release files or internal mirrored releases.
WAHIS_EXPORT_URL=
# WOAH disease reference is separate from WAHIS surveillance. Point this to a CSV/JSON export,
# for example a Supabase Storage object such as ontology-provider-exports/woah/latest.csv.
WOAH_DISEASE_REFERENCE_URL=
# CDC Open Data should point to a Socrata dataset endpoint such as https://data.cdc.gov/resource/<dataset-id>.json.
CDC_OPEN_DATA_URL=
# Optional Socrata app token for higher CDC Open Data API throttling.
CDC_OPEN_DATA_APP_TOKEN=
# Licensed releases must be obtained and hosted/mirrored according to the license before enabling.
SNOMED_CT_RELEASE_URL=
VENOM_RELEASE_URL=
GLOBAL_ONTOLOGY_MAX_NODES_PER_PROVIDER=5000
GLOBAL_ONTOLOGY_MAX_RELATIONSHIPS_PER_PROVIDER=10000
VETIOS_OUTBOX_BATCH_SIZE=25
VETIOS_OUTBOX_CRON_MAX_BATCHES=4
OUTBOX_WEBHOOK_SIGNING_SECRET=replace-with-webhook-signing-secret

# Stripe + Developer API Billing
STRIPE_SECRET_KEY=sk_live_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_SANDBOX_PRICE_ID=price_sandbox_replace_me
STRIPE_CLINIC_PRICE_ID=price_clinic_replace_me
STRIPE_RESEARCH_PRICE_ID=price_research_replace_me
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_replace_me
API_KEY_SIGNING_SECRET=replace-with-32-char-random-hex
VETIOS_API_BASE_URL=https://api.vetios.tech

# ─── Phase 2 Intelligence Stack ───────────────────────────────────────────────
# CRON_SECRET: authorises Vercel cron scheduler — add to Vercel dashboard too
# CRON_SECRET is set in Vercel dashboard only — never commit the real value here
VETIOS_EMBEDDING_DIMENSIONS=1536
VETIOS_EMBEDDING_MODEL=text-embedding-3-large
VETIOS_POPULATION_SIGNAL_ENABLED=true
VETIOS_OUTBREAK_ALERT_WEBHOOK=
VETIOS_ACTIVE_LEARNING_ENABLED=true
VETIOS_AL_UNCERTAINTY_THRESHOLD=0.55
VETIOS_CONSTITUTIONAL_AI_ENABLED=true
VETIOS_CONFIDENCE_GATE_THRESHOLD=0.65
VETIOS_MULTI_AGENT_ENABLED=true
NEXT_PUBLIC_APP_URL=https://app.vetios.tech

# Simulation closed-loop controls
VETIOS_SIMULATION_HEARTBEAT_INTERVAL_MS=10000
VETIOS_SIMULATION_WATCHDOG_ENABLED=true
VETIOS_SIMULATION_WATCHDOG_TIMEOUT_BUFFER_S=120
VETIOS_SIMULATION_MAX_CONCURRENT_AGENTS=20
VETIOS_SIMULATION_CALIBRATION_MODEL_CLASS=production
VETIOS_SIMULATION_REGRESSION_REQUIRED_BEFORE_PROMOTE=true
VETIOS_ADVERSARIAL_ENABLED=true
VETIOS_ADVERSARIAL_TYPES=contradictory_vitals,weight_impossibility,symptom_saturation,species_mismatch,repeated_injection,empty_payload,confidence_boundary,rare_disease_hallucination
VETIOS_REGRESSION_ENABLED=true
VETIOS_REGRESSION_FAIL_THRESHOLD=0

# Moat expansion modules
# Enables append-only hash chain columns and audit verification/report APIs.
VETIOS_AUDIT_CHAIN_ENABLED=true
# Hash algorithm used for audit provenance.
VETIOS_AUDIT_HASH_ALGORITHM=sha256
# Enables species knowledge graph priors for exotic species routing.
VETIOS_EXOTIC_SPECIES_ENABLED=true
# Enables species knowledge graph priors for livestock species routing.
VETIOS_LIVESTOCK_SPECIES_ENABLED=true
# Version tag applied to species knowledge graph bootstrap runs.
VETIOS_SPECIES_KNOWLEDGE_GRAPH_VERSION=1
# Enables passive imaging connector ingestion and inference enrichment.
VETIOS_IMAGING_ENABLED=true
# Supabase Storage bucket for DICOM and imaging files.
VETIOS_IMAGING_BUCKET=vetios-imaging
# Maximum accepted imaging file size in megabytes.
VETIOS_IMAGING_MAX_FILE_MB=50
# Enables telemedicine intake sessions and SSE inference stream routes.
VETIOS_TELECONSULT_ENABLED=true
# Maximum extraction budget for optional owner description to symptom-code conversion.
VETIOS_TELECONSULT_EXTRACT_MAX_TOKENS=500
# Velocity required for an elevated outbreak cluster snapshot.
VETIOS_OUTBREAK_VELOCITY_THRESHOLD=0.40
# Velocity required for an alert outbreak cluster snapshot and webhook.
VETIOS_OUTBREAK_ALERT_THRESHOLD=1.0
# Minimum cases required before outbreak cluster escalation.
VETIOS_OUTBREAK_MIN_CASE_COUNT=5
# Enables passive wearable telemetry ingestion and anomaly events.
VETIOS_TELEMETRY_ENABLED=true
# Rolling telemetry anomaly window in minutes.
VETIOS_TELEMETRY_ANOMALY_WINDOW_MINUTES=15
# Standard deviation threshold for telemetry anomaly detection.
VETIOS_TELEMETRY_ANOMALY_STD_THRESHOLD=2.0
# Maximum readings accepted in a telemetry ingest batch.
VETIOS_TELEMETRY_BATCH_MAX_READINGS=500

# PharmacOS
VETIOS_PHARMACOS_ENABLED=true
VETIOS_PHARMACOS_FORMULARY_VERSION=1
VETIOS_PHARMACOS_FDA_SYNC_ENABLED=true
VETIOS_PHARMACOS_AUTO_PUBLISH_UPDATES=false
VETIOS_PHARMACOS_FORMULARY_AUTO_UPDATE=false
VETIOS_PHARMACOS_FDA_SYNC_URL=https://www.fda.gov/animal-veterinary/new-animal-drug-approvals
VETIOS_PHARMACOS_WEIGHT_VALIDATION_ENABLED=true
VETIOS_PHARMACOS_MAX_DRUG_CANDIDATES=6
VETIOS_PHARMACOS_N_DRUG_INTERACTION_LIMIT=5

# Clinical Images
VETIOS_CLINICAL_IMAGES_ENABLED=true
VETIOS_CLINICAL_IMAGES_PRIMARY_SOURCE=curated_library
VETIOS_CLINICAL_IMAGES_PMC_FALLBACK=true
VETIOS_CLINICAL_IMAGES_CURATED_BUCKET=vetios-clinical-images
VETIOS_CLINICAL_IMAGES_MIN_QUALITY_SCORE=0.7
VETIOS_CLINICAL_IMAGES_TERTIARY_WEB_SEARCH=false
VETIOS_PMC_EUTILS_BASE_URL=https://eutils.ncbi.nlm.nih.gov/entrez/eutils

# Ask VetIOS
VETIOS_ASK_STREAMING_ENABLED=true
VETIOS_ASK_MAX_DISEASE_OVERVIEW_TOKENS=800
VETIOS_ASK_SOURCE_PRECISION_FILTER=true
VETIOS_ASK_QUERY_HISTORY_ENABLED=true
VETIOS_ASK_FEEDBACK_ENABLED=true

# Deprecated image-search fallbacks. Keep unset unless explicitly enabling tertiary web search.
# BING_IMAGE_SEARCH_API_KEY=
# GOOGLE_CSE_API_KEY=
# GOOGLE_CSE_ID=
