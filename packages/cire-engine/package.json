{
    "name": "@vetios/cire-engine",
    "version": "1.0.0",
    "private": false,
    "license": "MIT",
    "type": "module",
    "main": "./src/index.ts",
    "types": "./src/index.ts",
    "exports": {
        ".": {
            "types": "./src/index.ts",
            "default": "./src/index.ts"
        }
    },
    "bin": {
        "cire-conformance": "./dist/conformance-cli.js"
    },
    "files": [
        "dist",
        "fixtures",
        "README.md",
        "package.json"
    ],
    "scripts": {
        "typecheck": "tsc --noEmit",
        "build": "tsc",
        "test": "pnpm run build && node ./dist/conformance-cli.js ./fixtures/cire-conformance-v1.valid.json --strict",
        "conformance": "node ./dist/conformance-cli.js",
        "clean": "rm -rf dist"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "@vetios/tsconfig": "workspace:*",
        "typescript": "^5.7.0"
    }
}
