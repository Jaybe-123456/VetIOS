{
    "$schema": "https://turbo.build/schema.json",
    "globalDependencies": [
        "**/.env.*local"
    ],
    "globalPassThroughEnv": [
        "SUPABASE_URL",
        "SUPABASE_ANON_KEY",
        "SUPABASE_SERVICE_ROLE_KEY",
        "NEXT_PUBLIC_SUPABASE_URL",
        "NEXT_PUBLIC_SUPABASE_ANON_KEY",
        "NEXT_PUBLIC_SITE_URL",
        "NEXT_PUBLIC_TURNSTILE_SITE_KEY",
        "OPENAI_API_KEY",
        "ANTHROPIC_API_KEY",
        "AI_PROVIDER_API_KEY",
        "AI_PROVIDER_BASE_URL",
        "AI_PROVIDER_DEFAULT_MODEL",
        "AI_PROVIDER_NAME",
        "AI_PROVIDER_EMBEDDING_MODEL",
        "GOOGLE_CSE_ID",
        "GOOGLE_CSE_API_KEY",
        "ML_SERVER_URL",
        "LOG_LEVEL",
        "SITE_URL",
        "RESEND_API_KEY",
        "TWILIO_ACCOUNT_SID",
        "TWILIO_AUTH_TOKEN",
        "TWILIO_FROM_NUMBER",
        "TWILIO_MESSAGING_SERVICE_SID",
        "PETPASS_EMAIL_FROM",
        "PETPASS_EMAIL_REPLY_TO",
        "VETIOS_EMAIL_FROM",
        "VETIOS_EMAIL_REPLY_TO",
        "CRON_SECRET",
        "VETIOS_PUBLIC_RAG_TENANT_ID",
        "VETIOS_RAG_EMBEDDING_MODEL",
        "VETIOS_RAG_EUTILS_BASE_URL",
        "VETIOS_RAG_CONNECTOR_MAX_RECORDS",
        "VETIOS_NCBI_TOOL",
        "VETIOS_NCBI_EMAIL",
        "VETIOS_NCBI_API_KEY",
        "VETIOS_OUTBOX_BATCH_SIZE",
        "VETIOS_OUTBOX_CRON_MAX_BATCHES",
        "OUTBOX_WEBHOOK_SIGNING_SECRET",
        "STRIPE_SECRET_KEY",
        "STRIPE_WEBHOOK_SECRET",
        "STRIPE_RESEARCH_PRICE_ID",
        "STRIPE_CLINIC_PRICE_ID",
        "STRIPE_SANDBOX_PRICE_ID",
        "VETIOS_API_BASE_URL",
        "API_KEY_SIGNING_SECRET",
        "TURNSTILE_SECRET_KEY",
        "AUTH_CAPTCHA_AFTER_FAILURES",
        "VETIOS_ADMIN_EMAIL",
        "NEXT_PUBLIC_VETIOS_DEV_BYPASS",
        "DEBUG_INFERENCE",
        "NODE_ENV",
        "VETIOS_FINGERPRINT_KEY",
        "HF_PROVIDER_API_KEY",
        "HF_PROVIDER_BASE_URL",
        "HF_PROVIDER_MODEL",
        "VETIOS_DEV_BYPASS",
        "VETIOS_LOCAL_REASONER",
        "VETIOS_INTERNAL_API_TOKEN",
        "VETIOS_QUANTUM_BACKEND",
        "PENNYLANE_BRAKET_DEVICE_ARN",
        "PENNYLANE_BRAKET_SHOTS",
        "AWS_REGION",
        "AWS_DEFAULT_REGION",
        "BRAKET_S3_BUCKET"
    ],
    "tasks": {
        "build": {
            "dependsOn": [
                "^build"
            ],
            "env": [
                "SUPABASE_URL",
                "SUPABASE_ANON_KEY",
                "SUPABASE_SERVICE_ROLE_KEY",
                "NEXT_PUBLIC_SUPABASE_URL",
                "NEXT_PUBLIC_SUPABASE_ANON_KEY",
                "NEXT_PUBLIC_SITE_URL",
                "NEXT_PUBLIC_TURNSTILE_SITE_KEY",
                "OPENAI_API_KEY",
                "ANTHROPIC_API_KEY",
                "AI_PROVIDER_API_KEY",
                "AI_PROVIDER_BASE_URL",
                "AI_PROVIDER_DEFAULT_MODEL",
                "AI_PROVIDER_NAME",
                "AI_PROVIDER_EMBEDDING_MODEL",
                "GOOGLE_CSE_ID",
                "GOOGLE_CSE_API_KEY",
                "ML_SERVER_URL",
                "LOG_LEVEL",
                "SITE_URL",
                "RESEND_API_KEY",
                "TWILIO_ACCOUNT_SID",
                "TWILIO_AUTH_TOKEN",
                "TWILIO_FROM_NUMBER",
                "TWILIO_MESSAGING_SERVICE_SID",
                "PETPASS_EMAIL_FROM",
                "PETPASS_EMAIL_REPLY_TO",
                "VETIOS_EMAIL_FROM",
                "VETIOS_EMAIL_REPLY_TO",
                "CRON_SECRET",
                "VETIOS_PUBLIC_RAG_TENANT_ID",
                "VETIOS_RAG_EMBEDDING_MODEL",
                "VETIOS_RAG_EUTILS_BASE_URL",
                "VETIOS_RAG_CONNECTOR_MAX_RECORDS",
                "VETIOS_NCBI_TOOL",
                "VETIOS_NCBI_EMAIL",
                "VETIOS_NCBI_API_KEY",
                "VETIOS_OUTBOX_BATCH_SIZE",
                "VETIOS_OUTBOX_CRON_MAX_BATCHES",
                "OUTBOX_WEBHOOK_SIGNING_SECRET",
                "STRIPE_SECRET_KEY",
                "STRIPE_WEBHOOK_SECRET",
                "STRIPE_RESEARCH_PRICE_ID",
                "STRIPE_CLINIC_PRICE_ID",
                "STRIPE_SANDBOX_PRICE_ID",
                "VETIOS_API_BASE_URL",
                "API_KEY_SIGNING_SECRET",
                "TURNSTILE_SECRET_KEY",
                "AUTH_CAPTCHA_AFTER_FAILURES",
                "VETIOS_ADMIN_EMAIL",
                "NEXT_PUBLIC_VETIOS_DEV_BYPASS",
                "DEBUG_INFERENCE",
                "NODE_ENV",
                "VETIOS_FINGERPRINT_KEY",
                "HF_PROVIDER_API_KEY",
                "HF_PROVIDER_BASE_URL",
                "HF_PROVIDER_MODEL",
                "VETIOS_DEV_BYPASS",
                "VETIOS_LOCAL_REASONER",
                "VETIOS_INTERNAL_API_TOKEN",
                "VETIOS_QUANTUM_BACKEND",
                "PENNYLANE_BRAKET_DEVICE_ARN",
                "PENNYLANE_BRAKET_SHOTS",
                "AWS_REGION",
                "AWS_DEFAULT_REGION",
                "BRAKET_S3_BUCKET"
            ],
            "outputs": [
                ".next/**",
                "!.next/cache/**",
                "dist/**"
            ]
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "lint": {
            "dependsOn": [
                "^build"
            ]
        },
        "typecheck": {
            "dependsOn": [
                "^build"
            ]
        },
        "clean": {
            "cache": false
        }
    }
}
