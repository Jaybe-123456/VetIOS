{
    "$schema": "https://turbo.build/schema.json",
    "globalDependencies": [
        "**/.env.*local"
    ],
    "globalPassThroughEnv": [
        "SUPABASE_URL",
        "SUPABASE_ANON_KEY",
        "SUPABASE_SERVICE_ROLE_KEY",
        "NEXT_PUBLIC_SUPABASE_URL",
        "NEXT_PUBLIC_SUPABASE_ANON_KEY",
        "NEXT_PUBLIC_SITE_URL",
        "NEXT_PUBLIC_TURNSTILE_SITE_KEY",
        "OPENAI_API_KEY",
        "AI_PROVIDER_API_KEY",
        "AI_PROVIDER_BASE_URL",
        "AI_PROVIDER_DEFAULT_MODEL",
        "AI_PROVIDER_NAME",
        "AI_PROVIDER_EMBEDDING_MODEL",
        "ML_SERVER_URL",
        "LOG_LEVEL",
        "SITE_URL",
        "RESEND_API_KEY",
        "TWILIO_ACCOUNT_SID",
        "TWILIO_AUTH_TOKEN",
        "TWILIO_FROM_NUMBER",
        "TWILIO_MESSAGING_SERVICE_SID",
        "PETPASS_EMAIL_FROM",
        "PETPASS_EMAIL_REPLY_TO",
        "VETIOS_EMAIL_FROM",
        "VETIOS_EMAIL_REPLY_TO",
        "CRON_SECRET",
        "VETIOS_OUTBOX_BATCH_SIZE",
        "VETIOS_OUTBOX_CRON_MAX_BATCHES",
        "OUTBOX_WEBHOOK_SIGNING_SECRET",
        "STRIPE_SECRET_KEY",
        "STRIPE_WEBHOOK_SECRET",
        "STRIPE_RESEARCH_PRICE_ID",
        "STRIPE_CLINIC_PRICE_ID",
        "STRIPE_SANDBOX_PRICE_ID",
        "VETIOS_API_BASE_URL",
        "API_KEY_SIGNING_SECRET",
        "TURNSTILE_SECRET_KEY",
        "AUTH_CAPTCHA_AFTER_FAILURES",
        "VETIOS_ADMIN_EMAIL",
        "NEXT_PUBLIC_VETIOS_DEV_BYPASS"
    ],
    "tasks": {
        "build": {
            "dependsOn": [
                "^build"
            ],
            "env": [
                "SUPABASE_URL",
                "SUPABASE_ANON_KEY",
                "SUPABASE_SERVICE_ROLE_KEY",
                "NEXT_PUBLIC_SUPABASE_URL",
                "NEXT_PUBLIC_SUPABASE_ANON_KEY",
                "NEXT_PUBLIC_SITE_URL",
                "NEXT_PUBLIC_TURNSTILE_SITE_KEY",
                "OPENAI_API_KEY",
                "AI_PROVIDER_API_KEY",
                "AI_PROVIDER_BASE_URL",
                "AI_PROVIDER_DEFAULT_MODEL",
                "AI_PROVIDER_NAME",
                "AI_PROVIDER_EMBEDDING_MODEL",
                "ML_SERVER_URL",
                "LOG_LEVEL",
                "SITE_URL",
                "RESEND_API_KEY",
                "TWILIO_ACCOUNT_SID",
                "TWILIO_AUTH_TOKEN",
                "TWILIO_FROM_NUMBER",
                "TWILIO_MESSAGING_SERVICE_SID",
                "PETPASS_EMAIL_FROM",
                "PETPASS_EMAIL_REPLY_TO",
                "VETIOS_EMAIL_FROM",
                "VETIOS_EMAIL_REPLY_TO",
                "CRON_SECRET",
                "VETIOS_OUTBOX_BATCH_SIZE",
                "VETIOS_OUTBOX_CRON_MAX_BATCHES",
                "OUTBOX_WEBHOOK_SIGNING_SECRET",
                "STRIPE_SECRET_KEY",
                "STRIPE_WEBHOOK_SECRET",
                "STRIPE_RESEARCH_PRICE_ID",
                "STRIPE_CLINIC_PRICE_ID",
                "STRIPE_SANDBOX_PRICE_ID",
                "VETIOS_API_BASE_URL",
                "API_KEY_SIGNING_SECRET",
                "TURNSTILE_SECRET_KEY",
                "AUTH_CAPTCHA_AFTER_FAILURES",
                "VETIOS_ADMIN_EMAIL",
                "NEXT_PUBLIC_VETIOS_DEV_BYPASS"
            ],
            "outputs": [
                ".next/**",
                "!.next/cache/**",
                "dist/**"
            ]
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "lint": {
            "dependsOn": [
                "^build"
            ]
        },
        "typecheck": {
            "dependsOn": [
                "^build"
            ]
        },
        "clean": {
            "cache": false
        }
    }
}
