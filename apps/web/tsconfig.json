{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ],
      "@vetios/cire-engine": [
        "../../packages/cire-engine/src/index.ts"
      ],
      "@vetios/ask-vetios": [
        "../../packages/ask-vetios/src/index.ts"
      ],
      "@vetios/inference-schema": [
        "../../packages/inference-schema/src/index.ts"
      ],
      "@vetios/pharmacos": [
        "../../packages/pharmacos/src/index.ts"
      ],
      "@vetios/graph": [
        "../../packages/graph/src/index.ts"
      ],
      "@vetios/gaas": [
        "../../packages/gaas/src/index.ts"
      ]
    },
    "allowArbitraryExtensions": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/__tests__/**"
  ]
}
