    {"canonical_term":"weakness","category":"weak_signal","base_weight":0.26,"emergency_override":false,"rationale":"Nonspecific systemic weakness unless clustered."},
    {"canonical_term":"lethargy","category":"weak_signal","base_weight":0.22,"emergency_override":false,"rationale":"Low-specificity systemic signal unless paired with red flags."},
    {"canonical_term":"anorexia","category":"weak_signal","base_weight":0.2,"emergency_override":false,"rationale":"Low-specificity intake signal."},
    {"canonical_term":"hypersalivation","category":"primary_signal","base_weight":0.5,"emergency_override":false,"rationale":"Upper GI, oral, or toxicologic signal."},
    {"canonical_term":"myoclonus","category":"primary_signal","base_weight":0.82,"emergency_override":false,"rationale":"High-value neurologic infectious anchor."},
    {"canonical_term":"cough","category":"primary_signal","base_weight":0.44,"emergency_override":false,"rationale":"Moderate respiratory signal."},
    {"canonical_term":"honking_cough","category":"primary_signal","base_weight":0.76,"emergency_override":false,"rationale":"Upper-airway syndrome anchor."},
    {"canonical_term":"pneumonia","category":"primary_signal","base_weight":0.81,"emergency_override":false,"rationale":"Lower respiratory structural signal."},
    {"canonical_term":"nasal_discharge","category":"primary_signal","base_weight":0.41,"emergency_override":false,"rationale":"Respiratory infectious context signal."},
    {"canonical_term":"ocular_discharge","category":"primary_signal","base_weight":0.38,"emergency_override":false,"rationale":"Respiratory infectious context signal."},
    {"canonical_term":"dehydration","category":"primary_signal","base_weight":0.57,"emergency_override":false,"rationale":"Perfusion/volume modifier."},
    {"canonical_term":"abdominal_pain","category":"primary_signal","base_weight":0.73,"emergency_override":false,"rationale":"Strong abdominal disease signal."},
    {"canonical_term":"pleural_effusion","category":"red_flag","base_weight":0.9,"emergency_override":true,"rationale":"Critical respiratory structural finding."},
