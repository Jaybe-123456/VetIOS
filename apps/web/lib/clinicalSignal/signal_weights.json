    {"canonical_term":"stranguria","category":"primary_signal","base_weight":0.78,"emergency_override":false,"rationale":"Strong lower urinary tract signal."},
    {"canonical_term":"vomiting","category":"primary_signal","base_weight":0.58,"emergency_override":false,"rationale":"Moderate gastrointestinal signal."},
