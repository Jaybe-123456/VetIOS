    {"canonical_term":"hemorrhagic_diarrhea","category":"red_flag","base_weight":0.84,"emergency_override":true,"rationale":"High-severity gastrointestinal loss."},
    {"canonical_term":"fever","category":"primary_signal","base_weight":0.6,"emergency_override":false,"rationale":"Systemic inflammatory/infectious signal."},
