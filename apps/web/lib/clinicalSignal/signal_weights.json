    {"canonical_term":"open_mouth_breathing","category":"red_flag","base_weight":0.92,"emergency_override":true,"rationale":"Advanced respiratory compromise."},
    {"canonical_term":"abdominal_distension","category":"red_flag","base_weight":0.9,"emergency_override":true,"rationale":"Structural abdominal emergency anchor."},
    {"canonical_term":"retching_unproductive","category":"red_flag","base_weight":0.97,"emergency_override":true,"rationale":"Mechanical gastric emergency anchor."},
    {"canonical_term":"pale_mucous_membranes","category":"red_flag","base_weight":0.88,"emergency_override":true,"rationale":"Perfusion/shock red flag."},
