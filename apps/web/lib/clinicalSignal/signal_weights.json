    {"canonical_term":"stagnant_water_exposure","category":"contextual_signal","base_weight":0.46,"emergency_override":false,"rationale":"Environmental infectious exposure modifier."},
    {"canonical_term":"foreign_body_exposure","category":"contextual_signal","base_weight":0.52,"emergency_override":false,"rationale":"Mechanical GI modifier."},
    {"canonical_term":"toxin_exposure_possible","category":"contextual_signal","base_weight":0.56,"emergency_override":false,"rationale":"Toxicologic modifier."},
    {"canonical_term":"medication_exposure","category":"contextual_signal","base_weight":0.54,"emergency_override":false,"rationale":"Toxicologic modifier."},
    {"canonical_term":"heat_exposure","category":"contextual_signal","base_weight":0.58,"emergency_override":false,"rationale":"Heat injury modifier."},
    {"canonical_term":"trauma_exposure","category":"contextual_signal","base_weight":0.62,"emergency_override":false,"rationale":"Trauma modifier."},
    {"canonical_term":"recent_estrus","category":"contextual_signal","base_weight":0.57,"emergency_override":false,"rationale":"Reproductive risk modifier."},
    {"canonical_term":"intact_female","category":"contextual_signal","base_weight":0.49,"emergency_override":false,"rationale":"Reproductive context modifier."},
    {"canonical_term":"pregnant","category":"contextual_signal","base_weight":0.55,"emergency_override":false,"rationale":"Reproductive physiologic modifier."},
    {"canonical_term":"normal_activity","category":"contradiction_modifier","base_weight":0.24,"emergency_override":false,"rationale":"Counters severe illness clusters when co-reported."},
    {"canonical_term":"normal_appetite","category":"contradiction_modifier","base_weight":0.22,"emergency_override":false,"rationale":"Counters severe systemic illness clusters when co-reported."},
    {"canonical_term":"normal_urination","category":"contradiction_modifier","base_weight":0.24,"emergency_override":false,"rationale":"Counters obstructive urinary patterns when co-reported."},
    {"canonical_term":"normal_respiratory_effort","category":"contradiction_modifier","base_weight":0.24,"emergency_override":false,"rationale":"Counters respiratory distress reports when co-reported."},
    {"canonical_term":"pain_behavior_absent","category":"contradiction_modifier","base_weight":0.2,"emergency_override":false,"rationale":"Counters painful abdominal structural presentations when co-reported."}
  ],
  "combination_overrides": [
    {
      "id": "abdominal_mechanical_emergency_cluster",
      "label": "Mechanical abdominal emergency cluster",
      "when_all": ["retching_unproductive", "abdominal_distension"],
      "apply_to": ["retching_unproductive", "abdominal_distension"],
      "weight_delta": 0.18,
      "category_override": "red_flag",
      "emergency_override": true,
      "rationale": "Non-productive retching plus distension must outrank generic GI noise."
    },
    {
      "id": "shock_perfusion_cluster",
      "label": "Shock/perfusion cluster",
      "when_all": ["collapse", "pale_mucous_membranes"],
      "when_any": ["tachycardia", "dyspnea", "weakness"],
      "apply_to": ["collapse", "pale_mucous_membranes", "tachycardia", "dyspnea", "weakness"],
      "weight_delta": 0.12,
      "category_override": "red_flag",
      "emergency_override": true,
      "rationale": "Perfusion-shock cues amplify each other."
    },
    {
      "id": "respiratory_failure_cluster",
      "label": "Respiratory failure cluster",
      "when_any": ["dyspnea", "respiratory_distress"],
      "when_all": ["cyanosis"],
      "apply_to": ["dyspnea", "respiratory_distress", "cyanosis", "open_mouth_breathing"],
      "weight_delta": 0.14,
      "category_override": "red_flag",
      "emergency_override": true,
      "rationale": "Combined respiratory distress and oxygenation failure require top priority."
    },
    {
      "id": "upper_airway_anchor_cluster",
      "label": "Upper airway anchor cluster",
      "when_all": ["honking_cough"],
      "when_any": ["cough", "nasal_discharge", "ocular_discharge"],
      "apply_to": ["honking_cough", "cough", "nasal_discharge", "ocular_discharge"],
      "weight_delta": 0.1,
      "category_override": "primary_signal",
      "emergency_override": false,
      "rationale": "Honking cough should stay ahead of vague nonspecific respiratory noise."
    },
    {
      "id": "infectious_respiratory_context",
      "label": "Ocular-nasal infectious context",
      "when_all": ["nasal_discharge", "ocular_discharge"],
      "apply_to": ["nasal_discharge", "ocular_discharge"],
      "weight_delta": 0.09,
      "category_override": "primary_signal",
      "emergency_override": false,
      "rationale": "Paired ocular and nasal discharge increase syndrome coherence."
    },
    {
      "id": "urinary_obstruction_cluster",
      "label": "Urinary obstruction cluster",
      "when_all": ["urinary_obstruction_pattern"],
      "when_any": ["stranguria", "anuria", "oliguria"],
      "apply_to": ["urinary_obstruction_pattern", "stranguria", "anuria", "oliguria"],
      "weight_delta": 0.15,
      "category_override": "red_flag",
      "emergency_override": true,
      "rationale": "Obstructive urinary patterns should escalate before inference."
    },
    {
      "id": "foreign_body_context",
      "label": "Foreign-body mechanical context",
      "when_all": ["foreign_body_exposure"],
      "when_any": ["vomiting", "retching_unproductive", "abdominal_distension"],
      "apply_to": ["foreign_body_exposure", "vomiting", "retching_unproductive", "abdominal_distension"],
      "weight_delta": 0.09,
      "category_override": "primary_signal",
      "emergency_override": false,
      "rationale": "Foreign material history strengthens mechanical GI interpretation."
    },
    {
      "id": "toxicologic_context",
      "label": "Toxicologic context cluster",
      "when_any": ["toxin_exposure_possible", "medication_exposure"],
      "when_all": ["hypersalivation"],
      "apply_to": ["toxin_exposure_possible", "medication_exposure", "hypersalivation", "seizures"],
      "weight_delta": 0.08,
      "category_override": "contextual_signal",
      "emergency_override": false,
      "rationale": "Exposure history amplifies toxicologic symptom relevance."
    },
    {
      "id": "reproductive_context_cluster",
      "label": "Reproductive context cluster",
      "when_all": ["intact_female"],
      "when_any": ["recent_estrus", "vaginal_discharge", "pregnant", "postpartum"],
      "apply_to": ["intact_female", "recent_estrus", "vaginal_discharge", "pregnant", "postpartum"],
      "weight_delta": 0.1,
      "category_override": "contextual_signal",
      "emergency_override": false,
      "rationale": "Reproductive timing materially changes interpretation."
    }
  ]
}
